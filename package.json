{
  "name": "violet-pool-card",
  "version": "2.0.0-beta.1",
  "description": "Custom Lovelace card for Violet Pool Controller",
  "main": "dist/violet-pool-card.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/Xerolux/violet-pool-card.git"
  },
  "keywords": [
    "home-assistant",
    "lovelace",
    "custom-card",
    "pool",
    "violet",
    "hacs"
  ],
  "author": "Xerolux",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "node node_modules/rollup/dist/bin/rollup -c rollup.config.mjs",
    "build:info": "node scripts/generate-hacs-info.js",
    "watch": "node node_modules/rollup/dist/bin/rollup -c rollup.config.mjs --watch",
    "serve": "node node_modules/rollup/dist/bin/rollup -c rollup.config.mjs --watch --environment SERVE",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "home-assistant-js-websocket": "^9.6.0",
    "lit": "^3.3.2"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^8.0.0",
    "rollup": "^4.60.0",
    "rollup-plugin-serve": "^3.0.0",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "serialize-javascript": "^7.0.3"
  }
}
